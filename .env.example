# Copy this file to `.env` and fill in your real credentials.
# `.env` is gitignored — never commit it.
#
# Examples and tests load it via `python-dotenv`'s `load_dotenv()`. The
# client also reads these env vars directly in `__post_init__`.

# Pyth Pro access token (issued during onboarding).
PYTH_API_KEY=your-pyth-pro-access-token-here
